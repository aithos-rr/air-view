# OpenSky Network API credentials (OAuth2 client_credentials flow).
# Basic auth was deprecated mid-March 2025; new accounts must use OAuth2.
#
# How to obtain:
#   1. Sign in at https://opensky-network.org
#   2. Account → API Clients → "Create new client"
#   3. Download the credentials.json (or copy the values shown)
#   4. Paste clientId and clientSecret below
OPENSKY_CLIENT_ID=your_client_id_here
OPENSKY_CLIENT_SECRET=your_client_secret_here

# Server port. Defaults to 3000 in local dev. Railway injects PORT
# automatically in production — do NOT set it manually in Railway's
# variables panel.
PORT=3000

# Allowed CORS origin for the frontend in production. Optional: Railway
# public domains (*.railway.app, *.up.railway.app) are accepted by default.
# Set this if you serve the frontend from a custom domain.
# FRONTEND_ORIGIN=https://example.com
